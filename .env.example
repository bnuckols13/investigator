# OCCRP Aleph - get key from https://aleph.occrp.org profile settings
ALEPH_API_KEY=
ALEPH_HOST=https://aleph.occrp.org

# OpenSanctions - get key from https://www.opensanctions.org/account/
OPENSANCTIONS_API_KEY=

# SEC EDGAR - no key needed, but provide contact info per SEC policy
SEC_EDGAR_USER_AGENT=YourName your@email.com

# OpenFEC - get key from https://api.data.gov/signup/
OPENFEC_API_KEY=

# CourtListener - get token from https://www.courtlistener.com/help/api/rest/
COURTLISTENER_TOKEN=
